@article{barletta2026momentum,
  abbr        = {Front. Appl. Math.},
  title       = {Momentum accelerated power iterations and the restarted {L}anczos method},
  author      = {Barletta, Alessandro and Marshall, Nicholas and Pollock, Sara},
  journal     = {Frontiers in Applied Mathematics},
  year        = {2026},
  month       = {March},
  arxiv       = {2511.05364},
  doi         = {10.3934/fam.2026001},
  url         = {https://www.aimsciences.org/article/doi/10.3934/fam.2026001},
  bibtex_show = {true},
  selected    = {true},
  abstract    = {We compare two methods for finding extremal eigenvalues and eigenvectors: the restarted Lanczos method and momentum-accelerated power iterations. The convergence of both methods is based on ratios of Chebyshev polynomials evaluated at subdominant and dominant eigenvalues. We compare the theoretical convergence properties of both methods, determine the relative regimes where each is more efficient, and introduce a preconditioning technique for the restarted Lanczos method using momentum-accelerated power iterations.}
}
